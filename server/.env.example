# ─── Network ──────────────────────────────────────────────────────────
PORT=3001
BIND_HOST=0.0.0.0
MONGODB_URI=mongodb://mongo:password@mongodb:27017/squad-pm?authSource=admin

# ─── Secrets (REQUIRED in production) ─────────────────────────────────
# Both must be ≥ 32 chars and free of placeholder strings.
# Generate with: openssl rand -hex 32
JWT_SECRET=
JWT_REFRESH_SECRET=

# ─── Steam OpenID ─────────────────────────────────────────────────────
# API key: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=
# Public URL of this panel (https in production).
STEAM_REALM=https://your-panel.example.com
STEAM_RETURN_URL=https://your-panel.example.com/api/auth/steam/callback

# ─── Frontend URL (used for CORS + redirects) ─────────────────────────
CLIENT_URL=https://your-panel.example.com

# ─── Discord integration (optional) ───────────────────────────────────
# If DISCORD_APPROVER_ROLE_ID is unset, approve/reject buttons on bot
# notifications are disabled (fail-closed).
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_NOTIFICATION_CHANNEL_ID=
DISCORD_APPROVER_ROLE_ID=

# ─── IP / LAN install escape hatch (optional, OFF by default) ─────────
# Setting ALLOW_INSECURE_HTTP=true lets the server boot when CLIENT_URL /
# STEAM_REALM use http:// or a raw IP — handy for small/internal/test
# installs without a domain or TLS. NEVER turn this on for a public-facing
# deployment behind a real DNS name.
# ALLOW_INSECURE_HTTP=true
